<Window x:Class="NavisworksIfcExporter.UI.FbxExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar FBX por Sets  |  PHD Eng. Digital"
        Width="520" Height="520"
        MinWidth="400" MinHeight="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Sets -->
            <RowDefinition Height="Auto"/>  <!-- Instrução -->
            <RowDefinition Height="Auto"/>  <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- ===== Sets ===== -->
        <GroupBox Grid.Row="0" Header="Search Sets e Selection Sets (selecione os que deseja isolar)">
            <DockPanel>
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Selecionar todos" Height="24" Padding="8,0"
                            Margin="0,0,4,0" Click="BtnSelectAll_Click"/>
                    <Button Grid.Column="1" Content="Desmarcar todos" Height="24" Padding="8,0"
                            Margin="0,0,4,0" Click="BtnDeselectAll_Click"/>
                    <Button Grid.Column="3" Content="Atualizar" Width="80" Height="24"
                            Click="BtnRefresh_Click"/>
                </Grid>

                <TreeView x:Name="TreeSets" BorderBrush="#CCC" BorderThickness="1">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding"    Value="2,1"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsThreeState="False" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding TypeIcon}" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CountLabel}" Foreground="#888" FontSize="10"
                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </GroupBox>

        <!-- ===== Instrução ===== -->
        <GroupBox Grid.Row="1" Header="Como exportar FBX">
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#444" LineHeight="18">
                <Run>1. Selecione os sets acima e clique em </Run>
                <Run FontWeight="SemiBold">Isolar na viewport</Run>
                <Run>.</Run>
                <LineBreak/>
                <Run>2. No Navisworks, acesse </Run>
                <Run FontWeight="SemiBold">Arquivo → Exportar → FBX...</Run>
                <Run> e salve o arquivo.</Run>
                <LineBreak/>
                <Run>3. Clique em </Run>
                <Run FontWeight="SemiBold">Restaurar visibilidade</Run>
                <Run> para voltar ao estado original.</Run>
            </TextBlock>
        </GroupBox>

        <!-- ===== Botões ===== -->
        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" x:Name="BtnIsolate" Content="Isolar na viewport"
                    Width="140" Height="28" Margin="0,0,8,0" IsDefault="True"
                    Click="BtnIsolate_Click"/>
            <Button Grid.Column="1" x:Name="BtnRestore" Content="Restaurar visibilidade"
                    Width="150" Height="28" Margin="0,0,8,0" IsEnabled="False"
                    Click="BtnRestore_Click"/>
            <Button Grid.Column="3" Content="Fechar" Width="90" Height="28"
                    IsCancel="True" Click="BtnClose_Click"/>
        </Grid>
    </Grid>
</Window>
