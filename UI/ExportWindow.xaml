<Window x:Class="NavisworksIfcExporter.UI.ExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar IFC 4 — Navisworks"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="12">

        <!-- Arquivo de saída -->
        <GroupBox Header="Arquivo de saída">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtOutputPath" Grid.Column="0" Margin="0,0,4,0"
                         IsReadOnly="True" VerticalContentAlignment="Center" Height="26"/>
                <Button Grid.Column="1" Content="Procurar..." Width="80" Height="26"
                        Click="BtnBrowse_Click"/>
            </Grid>
        </GroupBox>

        <!-- Opções de exportação -->
        <GroupBox Header="Opções">
            <StackPanel>
                <CheckBox x:Name="ChkGeometry"   Content="Exportar geometria 3D (tessellada)" IsChecked="True"/>
                <CheckBox x:Name="ChkHidden"     Content="Incluir elementos ocultos" IsChecked="False"/>
                <CheckBox x:Name="ChkSelection"  Content="Exportar apenas seleção atual" IsChecked="False"/>
            </StackPanel>
        </GroupBox>

        <!-- Metadados -->
        <GroupBox Header="Metadados do arquivo IFC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Autor:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtAuthor" Grid.Row="0" Grid.Column="1" Margin="0,2"
                         Height="24" VerticalContentAlignment="Center" Text="Exportador"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Organização:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtOrganization" Grid.Row="1" Grid.Column="1" Margin="0,2"
                         Height="24" VerticalContentAlignment="Center" Text="PHD"/>
            </Grid>
        </GroupBox>

        <!-- Log / Progresso -->
        <GroupBox Header="Progresso">
            <TextBox x:Name="TxtLog" Height="70" IsReadOnly="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#F8F8F8" FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <!-- Botões de ação -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Mapeamento de propriedades..." Height="28"
                    Padding="10,0" Click="BtnMapping_Click"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnExport" Content="Exportar" Width="90" Height="28" Margin="0,0,8,0"
                        IsDefault="True" Click="BtnExport_Click"/>
                <Button Content="Fechar" Width="90" Height="28" IsCancel="True" Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>

    </StackPanel>
</Window>
