<Window x:Class="NavisworksIfcExporter.UI.QtoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QTO Auto Attach  |  PHD Eng. Digital"
        Width="760" Height="680"
        MinWidth="600" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Modo de mapeamento (tabs) -->
            <RowDefinition Height="Auto"/>  <!-- Modo de atualização + histórico -->
            <RowDefinition Height="*"/>     <!-- DataGrid de regras -->
            <RowDefinition Height="110"/>   <!-- Log -->
            <RowDefinition Height="Auto"/>  <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- ===== Modo de mapeamento ===== -->
        <TabControl x:Name="TabMode" Grid.Row="0" Margin="0,0,0,4"
                    SelectionChanged="TabMode_SelectionChanged">

            <!-- TAB 1: Por Search Set -->
            <TabItem Header="Por Search Set">
                <Grid Margin="4,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="+ Adicionar linha" Height="24" Padding="8,0"
                            Margin="0,0,6,0" Click="BtnAddSetRule_Click"/>
                    <Button Grid.Column="1" Content="− Remover" Height="24" Padding="8,0"
                            Margin="0,0,6,0" Click="BtnRemoveSetRule_Click"/>
                    <Button Grid.Column="3" Content="Atualizar listas" Height="24" Padding="8,0"
                            Click="BtnRefreshLists_Click"/>
                </Grid>
            </TabItem>

            <!-- TAB 2: Por Propriedade -->
            <TabItem Header="Por Valor de Propriedade">
                <Grid Margin="4,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="+ Adicionar linha" Height="24" Padding="8,0"
                            Margin="0,0,6,0" Click="BtnAddPropRule_Click"/>
                    <Button Grid.Column="1" Content="− Remover" Height="24" Padding="8,0"
                            Margin="0,0,6,0" Click="BtnRemovePropRule_Click"/>
                    <Button Grid.Column="3" Content="⟳ Escanear modelo" Height="24" Padding="8,0"
                            Click="BtnScanModel_Click"/>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- ===== Modo de atualização ===== -->
        <GroupBox Grid.Row="1" Header="Modo de atualização">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="RbClearReattach" Content="Atualizar tudo (limpar vínculos e reconectar)"
                             IsChecked="True" VerticalAlignment="Center" Margin="0,0,20,0"/>
                <RadioButton x:Name="RbAppendOnly" Content="Adicionar apenas novos elementos"
                             VerticalAlignment="Center" Margin="0,0,20,0"/>
                <CheckBox x:Name="ChkExportHistory" Content="Exportar CSV histórico antes de atualizar"
                          IsChecked="True" VerticalAlignment="Center"/>
            </StackPanel>
        </GroupBox>

        <!-- ===== Grids de mapeamento (alternados via Visibility) ===== -->
        <Grid Grid.Row="2">

            <!-- Grid SearchSet -->
            <DataGrid x:Name="GridSetRules"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserSortColumns="False" CanUserReorderColumns="False"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowHeight="26" FontSize="11" BorderBrush="#CCC" BorderThickness="1"
                      Visibility="Visible">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Search Set / Selection Set" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SetName}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True" StaysOpenOnEdit="True"
                                          Text="{Binding SetName, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Height="24"
                                          Loaded="CmbSetName_Loaded"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Item QTO (Código ou Nome)" Width="2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemName}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True" StaysOpenOnEdit="True"
                                          Text="{Binding ItemCode, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="DisplayLabel"
                                          SelectedValuePath="Code"
                                          BorderThickness="0" Height="24"
                                          Loaded="CmbQtoItem_Loaded"
                                          SelectionChanged="CmbQtoItem_SelectionChanged"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Grid Propriedades -->
            <DataGrid x:Name="GridPropRules"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" CanUserDeleteRows="False"
                      CanUserSortColumns="False" CanUserReorderColumns="False"
                      SelectionMode="Single" SelectionUnit="FullRow"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      RowHeight="26" FontSize="11" BorderBrush="#CCC" BorderThickness="1"
                      Visibility="Collapsed">

                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Categoria" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Category}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True" StaysOpenOnEdit="True"
                                          Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                          BorderThickness="0" Height="24"
                                          Loaded="CmbPropCategory_Loaded"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Propriedade" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PropertyName}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True" StaysOpenOnEdit="True"
                                          Text="{Binding PropertyName, UpdateSourceTrigger=PropertyChanged}"
                                          Tag="{Binding Category}"
                                          BorderThickness="0" Height="24"
                                          Loaded="CmbPropProperty_Loaded"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Valor" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Value}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0" VerticalContentAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Item QTO (Código ou Nome)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ItemName}" Margin="4,0" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox IsEditable="True" StaysOpenOnEdit="True"
                                          Text="{Binding ItemCode, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="DisplayLabel"
                                          SelectedValuePath="Code"
                                          BorderThickness="0" Height="24"
                                          Loaded="CmbQtoItemProp_Loaded"
                                          SelectionChanged="CmbQtoItemProp_SelectionChanged"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ===== Log ===== -->
        <GroupBox Grid.Row="3" Header="Resultado">
            <TextBox x:Name="TxtLog" IsReadOnly="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#F8F8F8" FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <!-- ===== Botões ===== -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="BtnRun" Content="▶  Executar Auto Attach" Width="160" Height="30"
                    Margin="0,0,8,0" IsDefault="True" Click="BtnRun_Click"/>
            <Button Content="Fechar" Width="90" Height="30"
                    IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
