<Window x:Class="NavisworksIfcExporter.UI.MappingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mapeamento de Propriedades"
        Width="860" Height="540"
        MinWidth="640" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Instrução -->
        <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap" Foreground="#555" FontSize="12"
                   Text="Defina regras para renomear, reclassificar ou excluir propriedades no IFC exportado. Campos em branco são curingas (combinam com qualquer valor). A primeira regra que casar é aplicada — a ordem importa."/>

        <!-- DataGrid principal -->
        <DataGrid Grid.Row="1" x:Name="GridRules"
                  AutoGenerateColumns="False"
                  CanUserAddRows="True" CanUserDeleteRows="False"
                  CanUserReorderColumns="False" CanUserResizeRows="False"
                  CanUserSortColumns="False"
                  SelectionMode="Extended" SelectionUnit="FullRow"
                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeight="26" FontSize="12"
                  BorderBrush="#CCC" BorderThickness="1"
                  VerticalScrollBarVisibility="Auto">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F0F0F0"/>
                    <Setter Property="Padding" Value="6,4"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="BorderBrush" Value="#CCC"/>
                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Exclude}" Value="True">
                            <Setter Property="Foreground" Value="#999"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <!-- Categoria origem -->
                <DataGridTextColumn Header="Categoria origem (Navisworks)"
                                    Binding="{Binding SourcePset, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Propriedade origem -->
                <DataGridTextColumn Header="Propriedade origem"
                                    Binding="{Binding SourceProperty, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Categoria destino (IFC Pset) — ComboBox editável -->
                <DataGridTemplateColumn Header="Categoria destino (IFC Pset)" Width="*" SortMemberPath="TargetPset">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding TargetPset}" Margin="4,0" VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox IsEditable="True"
                                      Text="{Binding TargetPset, UpdateSourceTrigger=PropertyChanged}"
                                      x:Name="CmbTargetPset"
                                      BorderThickness="0"
                                      Loaded="CmbTargetPset_Loaded"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Propriedade destino -->
                <DataGridTextColumn Header="Propriedade destino"
                                    Binding="{Binding TargetProperty, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock"><Setter Property="Margin" Value="4,0"/></Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Excluir -->
                <DataGridCheckBoxColumn Header="Excluir" Binding="{Binding Exclude}" Width="60">
                    <DataGridCheckBoxColumn.HeaderStyle>
                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.HeaderStyle>
                    <DataGridCheckBoxColumn.ElementStyle>
                        <Style TargetType="CheckBox">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                        </Style>
                    </DataGridCheckBoxColumn.ElementStyle>
                </DataGridCheckBoxColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Toolbar -->
        <Grid Grid.Row="2" Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="+ Adicionar" Width="88" Height="26" Margin="0,0,4,0" Click="BtnAdd_Click"/>
                <Button Content="− Remover" Width="88" Height="26" Margin="0,0,4,0" Click="BtnRemove_Click"/>
                <Button Content="↑ Subir" Width="72" Height="26" Margin="0,0,4,0" Click="BtnMoveUp_Click"/>
                <Button Content="↓ Descer" Width="72" Height="26" Click="BtnMoveDown_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Importar JSON..." Width="110" Height="26" Margin="0,0,4,0" Click="BtnImport_Click"/>
                <Button Content="Exportar JSON..." Width="110" Height="26" Click="BtnExport_Click"/>
            </StackPanel>
        </Grid>

        <!-- OK / Cancelar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="90" Height="28" Margin="0,0,8,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button Content="Cancelar" Width="90" Height="28" IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
