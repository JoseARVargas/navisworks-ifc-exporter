<Window x:Class="NavisworksIfcExporter.UI.HighlightSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Realçar Seleção  |  PHD Eng. Digital"
        Width="420" Height="320"
        MinWidth="360" MinHeight="280"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Topmost="True"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Status -->
            <RowDefinition Height="Auto"/>  <!-- Cor -->
            <RowDefinition Height="Auto"/>  <!-- Transparência -->
            <RowDefinition Height="Auto"/>  <!-- Preview -->
            <RowDefinition Height="Auto"/>  <!-- Barra de progresso -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>  <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- Status -->
        <Border Grid.Row="0" Background="#F0F4FF" BorderBrush="#C8D8F0" BorderThickness="1"
                CornerRadius="3" Padding="10,6" Margin="0,0,0,10">
            <TextBlock x:Name="TxtStatus" Text="Carregando..." FontSize="11"
                       TextWrapping="Wrap" Foreground="#334"/>
        </Border>

        <!-- Cor dos não selecionados -->
        <GroupBox Grid.Row="1" Header="Cor dos não selecionados" Margin="0,0,0,6" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Swatch clickável -->
                <Border Grid.Column="0" x:Name="ColorSwatch"
                        Height="28" Margin="0,0,8,0"
                        BorderBrush="#888" BorderThickness="1" CornerRadius="2"
                        Background="LightGray" Cursor="Hand"
                        MouseLeftButtonUp="ColorSwatch_Click"
                        ToolTip="Clique para escolher a cor"/>

                <Button Grid.Column="1" Content="Escolher cor..." Height="28" Padding="10,0"
                        Margin="0,0,6,0" Click="BtnPickColor_Click"/>

                <!-- Presets rápidos -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Height="28" Width="28" Margin="0,0,3,0" Click="BtnPreset_Click"
                            Tag="128,128,128" ToolTip="Cinza"
                            Background="Gray" BorderBrush="#555"/>
                    <Button Height="28" Width="28" Margin="0,0,3,0" Click="BtnPreset_Click"
                            Tag="173,216,230" ToolTip="Azul claro"
                            Background="LightBlue" BorderBrush="#99B"/>
                    <Button Height="28" Width="28" Click="BtnPreset_Click"
                            Tag="200,200,200" ToolTip="Cinza claro"
                            Background="#C8C8C8" BorderBrush="#999"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Transparência -->
        <GroupBox Grid.Row="2" Header="Transparência dos não selecionados" Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="48"/>
                </Grid.ColumnDefinitions>
                <Slider x:Name="SliderTransp"
                        Minimum="0" Maximum="100" Value="70"
                        TickFrequency="10" IsSnapToTickEnabled="False"
                        VerticalAlignment="Center"
                        ValueChanged="SliderTransp_ValueChanged"/>
                <TextBlock x:Name="TxtTranspPct" Grid.Column="1"
                           Text="70%" VerticalAlignment="Center"
                           HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </Grid>
        </GroupBox>

        <!-- Preview em tempo real -->
        <CheckBox Grid.Row="3" x:Name="ChkLivePreview"
                  Content="Preview em tempo real (pode ser lento em modelos grandes)"
                  Margin="2,6,0,0" FontSize="11"
                  Checked="ChkLivePreview_Changed" Unchecked="ChkLivePreview_Changed"/>

        <!-- Barra de progresso -->
        <Grid Grid.Row="4" x:Name="PanelProgress" Visibility="Collapsed" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="48"/>
            </Grid.ColumnDefinitions>
            <ProgressBar x:Name="PrgBar" Height="14" Minimum="0" Maximum="100" Value="0"
                         Background="#EEE" Foreground="#1976D2"/>
            <TextBlock x:Name="TxtPct" Grid.Column="1" Text="0%"
                       VerticalAlignment="Center" HorizontalAlignment="Center"
                       FontWeight="SemiBold" FontSize="10"/>
        </Grid>

        <!-- Botões -->
        <StackPanel Grid.Row="6" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnApply" Content="Aplicar" Width="90" Height="30"
                    Margin="0,0,6,0" IsDefault="True" Click="BtnApply_Click"/>
            <Button x:Name="BtnRestore" Content="Restaurar" Width="90" Height="30"
                    Margin="0,0,6,0" IsEnabled="False" Click="BtnRestore_Click"/>
            <Button Content="Fechar" Width="80" Height="30"
                    IsCancel="True" Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
