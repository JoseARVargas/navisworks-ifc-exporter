<Window x:Class="NavisworksIfcExporter.UI.SearchSetExportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Exportar IFC por Search Set — PHD Eng. Digital"
        Width="560" Height="680"
        MinWidth="440" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,4,0,4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,3"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>     <!-- Tree (expande com a janela) -->
            <RowDefinition Height="Auto"/>  <!-- Arquivo -->
            <RowDefinition Height="Auto"/>  <!-- Opções -->
            <RowDefinition Height="Auto"/>  <!-- Metadados -->
            <RowDefinition Height="80"/>    <!-- Progresso (altura fixa pequena) -->
            <RowDefinition Height="Auto"/>  <!-- Botões -->
        </Grid.RowDefinitions>

        <!-- ===== Tree de Search Sets ===== -->
        <GroupBox Grid.Row="0" Header="Search Sets e Selection Sets">
            <DockPanel>

                <!-- Barra de filtro + Atualizar -->
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtFilter" Grid.Column="0" Height="24" Margin="0,0,6,0"
                             VerticalContentAlignment="Center"
                             TextChanged="TxtFilter_TextChanged"/>
                    <Button Grid.Column="1" Content="Selecionar todos" Height="24" Padding="8,0"
                            Margin="0,0,4,0" Click="BtnSelectAll_Click"/>
                    <Button Grid.Column="2" Content="Atualizar" Width="80" Height="24"
                            Click="BtnRefresh_Click"/>
                </Grid>

                <!-- TreeView com checkboxes -->
                <TreeView x:Name="TreeSets"
                          BorderBrush="#CCC" BorderThickness="1"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Padding"    Value="2,1"/>
                        </Style>
                    </TreeView.ItemContainerStyle>

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Margin="0,1">
                                <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                          IsThreeState="False"
                                          VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding TypeIcon}"
                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CountLabel}"
                                           Foreground="#888" FontSize="10"
                                           Margin="4,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

            </DockPanel>
        </GroupBox>

        <!-- ===== Arquivo de saída ===== -->
        <GroupBox Grid.Row="1" Header="Arquivo de saída">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtOutputPath" Grid.Column="0" Margin="0,0,4,0"
                         IsReadOnly="True" VerticalContentAlignment="Center" Height="26"/>
                <Button Grid.Column="1" Content="Procurar..." Width="80" Height="26"
                        Click="BtnBrowse_Click"/>
            </Grid>
        </GroupBox>

        <!-- ===== Opções ===== -->
        <GroupBox Grid.Row="2" Header="Opções">
            <StackPanel>
                <CheckBox x:Name="ChkGeometry" Content="Exportar geometria 3D (tessellada)" IsChecked="True"/>
                <CheckBox x:Name="ChkHidden"   Content="Incluir elementos ocultos" IsChecked="False"/>
            </StackPanel>
        </GroupBox>

        <!-- ===== Metadados ===== -->
        <GroupBox Grid.Row="3" Header="Metadados do arquivo IFC">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Grid.Column="0" Content="Autor:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtAuthor" Grid.Row="0" Grid.Column="1" Margin="0,2"
                         Height="24" VerticalContentAlignment="Center" Text="Exportador"/>
                <Label Grid.Row="1" Grid.Column="0" Content="Organização:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtOrganization" Grid.Row="1" Grid.Column="1" Margin="0,2"
                         Height="24" VerticalContentAlignment="Center" Text="PHD"/>
            </Grid>
        </GroupBox>

        <!-- ===== Progresso ===== -->
        <GroupBox Grid.Row="4" Header="Progresso">
            <TextBox x:Name="TxtLog" IsReadOnly="True"
                     TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                     Background="#F8F8F8" FontFamily="Consolas" FontSize="11"/>
        </GroupBox>

        <!-- ===== Botões ===== -->
        <Grid Grid.Row="5" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Mapeamento de propriedades..." Height="28"
                    Padding="10,0" Click="BtnMapping_Click"/>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="BtnExport" Content="Exportar" Width="90" Height="28"
                        Margin="0,0,8,0" IsDefault="True" Click="BtnExport_Click"/>
                <Button Content="Fechar" Width="90" Height="28" IsCancel="True"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
